		</ul>
		<!-- Postfix action -->
		<div class="row collapse">
			<form method="get" action="http://www.google.co.jp/search" target="_top">
				<div class="ten mobile-three columns">
					<input type="text" name="q" size="15" maxlength="255" value="Powered by Google" onClick="this.value='';">
				</div>
				<div class="two mobile-one columns">
					<div class="button expand postfix">
						<input type="image" src="/ErrPage/Message/images/icons/search.png" value="submit" alt="search">
					</div>
				</div>
				<input type="hidden" name="sitesearch" value="http://www.umin.ac.jp">
				<input type="hidden" name="domains" value="http://www.umin.ac.jp">
				<input type="hidden" name="hl" value="ja">
				<input type="hidden" name="num" value="20">
				<input type="hidden" name="ie" value="utf8">
				<input type="hidden" name="oe" value="utf8">
			</form>
		</div>
	</div>
</div>
</header>

<nav>
<div class="row">
<div class="twelve columns">
<ul class="nav-bar">
